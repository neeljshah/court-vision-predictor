# CourtVision -- Environment Variables Template
# Copy to .env and fill in real values. Never commit .env.

# -- Database ----------------------------------------------------------------
DATABASE_URL=postgresql://nba_user:PASSWORD@localhost:5432/nba_ai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nba_ai
POSTGRES_USER=nba_user
DB_PASSWORD=

# -- Redis --------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -- API Keys -----------------------------------------------------------------
NBA_API_KEY=
CLAUDE_API_KEY=
THE_ODDS_API_KEY=

# -- App -----------------------------------------------------------------------
ENV=development
DEBUG=false

# -- Backblaze B2 (cloud sync via rclone) ------------------------------------
B2_BUCKET=
B2_KEY_ID=
B2_APP_KEY=

# -- Exchange APIs (Phase 17) -----------------------------------------------
LIVE_BETTING=0                   # 0=paper/dry-run (default), 1=real orders — GLOBAL KILL SWITCH
KALSHI_ACCESS_KEY=               # From Kalshi dashboard Settings > API Keys
KALSHI_PRIVATE_KEY_PATH=         # Path to kalshi_private_key.pem (RSA-PSS 4096-bit)
KALSHI_ENV=demo                  # "demo" or "prod" (demo = api.elections.kalshi.com demo endpoint)
POLY_PRIVATE_KEY=                # Ethereum EOA private key hex (Polygon mainnet, holds USDC)
POLY_FUNDER_ADDRESS=             # Wallet address holding USDC on Polygon (chain_id=137)
SPORTTRADE_AVAILABLE=0           # 1 when Sporttrade direct API access confirmed (currently stub)
